{
    "Newspaper Comet": {
        "schema_name": "Newspaper Comet",
        "fields": {
            "year": "Year (YYYY)",
            "month": "Month (MM)",
            "day": "Day (DD)"
        },
        "defaults": {
            "identifier": "{year}_{month}_{day}_UCWV_Comet",
            "title": "University of Charleston Comet {year}_{month}_{day}",
            "date": "{year}-{month}-{day}",
            "mediatype": "text",
            "language": "en",
            "creator": "Schoenbaum Library",
            "collection": ""
        }
    },
    "Year Book": {
        "schema_name": "Year Book",
        "fields": {
            "year": "Year (YYYY)"
        },
        "defaults": {
            "identifier": "{year}_UCWV_Yearbook",
            "title": "{year} UCWV Yearbook",
            "date": "[{year}]",
            "mediatype": "text",
            "language": "en",
            "creator": "Schoenbaum Library",
            "collection": ""
        }
    }
}