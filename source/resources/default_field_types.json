{
    "Text": {
        "type": "string",
        "placeholder": "Enter text..."
    },
    "Number": {
        "type": "integer",
        "placeholder": "Numbers only"
    },
    "Decimal": {
        "type": "float",
        "placeholder": "e.g. 14.5"
    },
    "Year (YYYY)": {
        "type": "regex",
        "pattern": "^(18|19|20)\\d{2}$",
        "placeholder": "YYYY"
    },
    "Month (MM)": {
        "type": "regex",
        "pattern": "^(0?[1-9]|1[0-2])$",
        "placeholder": "MM"
    },
    "Day (DD)": {
        "type": "regex",
        "pattern": "^(0?[1-9]|[12]\\d|3[01])$",
        "placeholder": "DD"
    },
    "Date (YYYY-MM-DD)": {
        "type": "regex",
        "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$",
        "placeholder": "YYYY-MM-DD"
    }
}